# BanriTools — Variáveis de ambiente (exemplo)
# Copie para .env e preencha com seus valores. NUNCA commite o .env real.

# --- Cliente (expostas ao browser via Vite) ---
VITE_SUPABASE_URL="https://<seu-projeto>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<sua-publishable-key>"
VITE_SUPABASE_PROJECT_ID="<seu-project-id>"

# --- Servidor (apenas em server functions / edge) ---
SUPABASE_URL="https://<seu-projeto>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<sua-publishable-key>"

# CRÍTICO: chave de service role. Nunca exponha ao client, nunca prefixe com VITE_.
SUPABASE_SERVICE_ROLE_KEY="<sua-service-role-key>"
