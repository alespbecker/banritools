{
  "$schema": "https://design-tokens.org/draft",
  "meta": {
    "name": "Banritools Design Tokens",
    "version": "0.1.0",
    "source": "MIV Banrisul (cores de marca) + variantes acessíveis WCAG 2.1",
    "note": "Agnóstico de ferramenta. Light/dark via mapa semântico."
  },
  "color": {
    "primary": {
      "50": "#E8F4FF", "100": "#CFE8FF", "200": "#9CD2FF", "300": "#5CB7FF",
      "400": "#1F9FFF", "500": "#0094FF", "600": "#0077DB", "700": "#0061B0",
      "800": "#00477D", "900": "#002E52", "950": "#001A30"
    },
    "navy": { "600": "#1A1A6E", "700": "#0D0D5C", "800": "#000050", "900": "#00003A" },
    "turquoise": { "400": "#52E3D8", "500": "#1CD8CA", "600": "#12A99E", "700": "#0C857C", "800": "#085E58" },
    "purple": { "400": "#AD93FB", "500": "#936FFA", "600": "#7544EE", "700": "#5B30C4", "800": "#421F94" },
    "gray": {
      "0": "#FFFFFF", "50": "#F7F8FA", "100": "#EDF0F5", "200": "#DEE3EC",
      "300": "#C5CCDA", "400": "#98A2B5", "500": "#697387", "600": "#4B5566",
      "700": "#353D4B", "800": "#1F2530", "900": "#121620", "950": "#0A0D14"
    },
    "success": { "500": "#1FB866", "600": "#138A4A", "700": "#0E6E3B" },
    "warning": { "400": "#F6B43C", "500": "#E89510", "700": "#8A5808" },
    "error": { "500": "#F0463C", "600": "#D32A20", "700": "#A81F17" }
  },
  "semantic": {
    "light": {
      "bg": "{color.gray.50}", "surface": "{color.gray.0}", "surface-2": "{color.gray.100}",
      "border": "{color.gray.200}", "text": "{color.gray.900}", "text-muted": "{color.gray.600}",
      "text-disabled": "{color.gray.400}", "primary": "{color.primary.500}",
      "primary-strong": "{color.primary.600}", "on-primary": "{color.gray.0}",
      "link": "{color.primary.700}", "brand-deep": "{color.navy.800}",
      "success": "{color.success.700}", "warning": "{color.warning.700}",
      "error": "{color.error.600}", "focus-ring": "{color.primary.500}"
    },
    "dark": {
      "bg": "{color.gray.950}", "surface": "{color.gray.900}", "surface-2": "{color.gray.800}",
      "border": "{color.gray.700}", "text": "{color.gray.50}", "text-muted": "{color.gray.300}",
      "text-disabled": "{color.gray.500}", "primary": "{color.primary.400}",
      "primary-strong": "{color.primary.500}", "on-primary": "{color.gray.0}",
      "link": "{color.primary.300}", "brand-deep": "{color.navy.800}",
      "success": "{color.success.500}", "warning": "{color.warning.400}",
      "error": "{color.error.500}", "focus-ring": "{color.primary.400}"
    }
  },
  "typography": {
    "family": {
      "display": "Exo 2, system-ui, sans-serif",
      "body": "Source Sans 3, system-ui, sans-serif"
    },
    "scale": {
      "display": { "size": "3rem", "lineHeight": "1.1", "family": "display", "weight": 700 },
      "h1": { "size": "2.25rem", "lineHeight": "1.2", "family": "display", "weight": 700 },
      "h2": { "size": "1.875rem", "lineHeight": "1.25", "family": "display", "weight": 600 },
      "h3": { "size": "1.5rem", "lineHeight": "1.33", "family": "display", "weight": 600 },
      "xl": { "size": "1.25rem", "lineHeight": "1.4", "family": "body", "weight": 600 },
      "lg": { "size": "1.125rem", "lineHeight": "1.55", "family": "body", "weight": 500 },
      "base": { "size": "1rem", "lineHeight": "1.6", "family": "body", "weight": 400 },
      "sm": { "size": "0.875rem", "lineHeight": "1.5", "family": "body", "weight": 400 },
      "xs": { "size": "0.75rem", "lineHeight": "1.5", "family": "body", "weight": 500 }
    },
    "tracking": { "display": "0.01em", "body": "0" },
    "numeric": { "currency": "tabular-nums" }
  },
  "spacing": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px" },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "2xl": "28px", "full": "9999px" },
  "elevation": {
    "sm": "0 1px 2px rgba(0,0,80,.06)",
    "md": "0 4px 12px rgba(0,0,80,.08)",
    "lg": "0 12px 32px rgba(0,0,80,.12)"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "easing": { "standard": "cubic-bezier(0.2, 0, 0, 1)" }
  },
  "breakpoint": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" }
}
